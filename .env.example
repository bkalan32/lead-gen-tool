# Copy to .env and fill in. .env is gitignored — never commit real values.
# You'll find these in Supabase: Project Settings -> API.

# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# The "service_role" secret key (server-side only — full access).
# Used by the worker in Step 2. Do NOT expose this in a browser.
SUPABASE_SERVICE_KEY=
